ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: ElevenLabs premium TTS. If unset, the app falls back to
# browser SpeechSynthesis automatically. Get a key at https://elevenlabs.io.
ELEVENLABS_API_KEY=

# Optional: rate limiting. Set BOTH to enforce per-user/IP limits on the
# AI and TTS routes. If unset, rate limiting is a no-op. Create a free
# Redis database at https://upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: error monitoring. If set, server/client errors are sent to
# Sentry; if unset, errors are only logged to the console. Get a DSN at
# https://sentry.io.
SENTRY_DSN=

# Optional: Stripe billing (Premium tier = ElevenLabs voices + unlimited
# debates). Billing is enabled only when STRIPE_SECRET_KEY and
# STRIPE_PRICE_ID are both set; until then nothing is gated and all users
# get the current behavior. The webhook secret + Supabase service-role key
# are needed to sync subscription status. NEXT_PUBLIC_APP_URL is used to
# build Checkout/Portal redirect URLs.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
